<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="ap" prefHeight="211.0" prefWidth="227.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatroom.controllers.ProfilePictureController">
   <children>
      <Button fx:id="openFileButton" layoutY="2.0"
              mnemonicParsing="false" onAction="#addFile" text="Open file" />
      <Button fx:id="removePictureButton" layoutX="168.0" layoutY="2.0"
              mnemonicParsing="false" onAction="#removePicture" text="Remove" />
      <Label layoutY="27.0" prefHeight="17.0" prefWidth="65.0" text="File name" />
      <ImageView fx:id="profilePicture"
              fitHeight="120.0" fitWidth="120.0"
              layoutX="54.0" layoutY="46.0"
              pickOnBounds="true" preserveRatio="true" />
   </children>
</AnchorPane>

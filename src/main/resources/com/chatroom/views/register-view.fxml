<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatroom.client.controllers.RegisterController">

   <children>

      <ImageView fitHeight="600.0" fitWidth="800.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/background_image.png" />
         </image>
      </ImageView>

      <fx:include source="../components/menu-button.fxml"
                  AnchorPane.topAnchor="14.0"
                  AnchorPane.leftAnchor="14.0"/>

      <TextField fx:id="usernameRegisterField" layoutX="200.0" layoutY="206.0" promptText="Username" />
      <PasswordField fx:id="passwordRegisterField" layoutX="200.0" layoutY="240.0" promptText="Password" />
      <PasswordField fx:id="confirmPasswordRegisterField" layoutX="200.0" layoutY="275.0" promptText="Confirm Password" />
      <Button fx:id="registerButton" layoutX="243.0" layoutY="312.0" mnemonicParsing="false" onAction="#registerFunction" prefHeight="25.0" prefWidth="64.0" styleClass="menu-button" text="Register" />
   </children>
</AnchorPane>

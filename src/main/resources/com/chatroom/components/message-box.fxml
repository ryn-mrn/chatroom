<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox fx:id="messageContainer" maxHeight="-Infinity" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatroom.client.controllers.MessageController"
      stylesheets="@../styles.css">
    <children>
          <Button fx:id="profileButton" mnemonicParsing="false" onAction="#openProfile" prefHeight="50.0" prefWidth="50.0" />
      <VBox prefHeight="0.0" prefWidth="100.0">
         <children>
            <Label fx:id="usernameLabel" text="Username" />
             <Label fx:id="messageBox" maxWidth="300.0" minWidth="80.0"
                    style="-fx-background-color: green;" styleClass="message-box"
                    text="Label" wrapText="true" />
         </children>
      </VBox>
    </children>
</HBox>
